@startuml
title AI Spec Review – Backend Sequential LLM Calls (No Sub-Agents)
 
actor User
participant "UI (Web / FE)" as UI
participant "Backend API\n(FastAPI)" as API
participant "MCP\nConfluence" as MCP
participant "LLM Runtime\n(Copilot CLI / External LLM)" as LLM
 
User -> UI : Click "Review Spec"
UI -> API : POST /review-spec
 
note right of UI
{
  "confluence_link": "https://company.atlassian.net/wiki/xxxx",
  "auto_comment": true
}
end note
 
activate API
 
' --- Load spec ---
API -> MCP : get_page(confluence_link)
note right of API
{
  "page_url": "https://company.atlassian.net/wiki/xxxx"
}
end note
 
MCP --> API : spec_text + metadata
note left of MCP
{
  "spec_text": "...text only...",
  "metadata": {
    "title": "User Profile API Spec",
    "version_hint": "R19.0.1"
  }
}
end note
 
' --- Step 1: Classify document type ---
API -> LLM : prompt#1 – classify document_type
note right of API
{
  "input": {
    "spec_text": "..."
  }
}
end note
 
LLM --> API
note left
{
  "document_type": "BACKEND_API_SPEC",
  "confidence": 0.86
}
end note
 
' --- Step 2: Rubric review ---
API -> LLM : prompt#2 – review by rubric
note right of API
{
  "document_type": "BACKEND_API_SPEC",
  "spec_text": "...",
  "rubric_version": "2026"
}
end note
 
LLM --> API
note left
{
  "raw_topic_reviews": [
    {
      "topic": "A: Introduction",
      "subject": "Metadata",
      "status": "OK",
      "raw_score": 8,
      "review_notes": "...",
      "improvement_hint": "..."
    }
  ]
}
end note
 
' --- Step 3: Scoring & coaching ---
API -> LLM : prompt#3 – normalize score & coaching tone
note right of API
{
  "raw_topic_reviews": [...]
}
end note
 
LLM --> API
note left
{
  "topic_reviews": [
    {
      "topic": "...",
      "subject": "...",
      "status_with_score": "✅ OK (8/10)",
      "comment": "...",
      "example": "..."
    }
  ]
}
end note
 
' --- Step 4: Scenario coverage ---
API -> LLM : prompt#4 – generate scenario coverage
note right of API
{
  "spec_text": "...",
  "document_type": "BACKEND_API_SPEC"
}
end note
 
LLM --> API
note left
{
  "scenarios": [
    {
      "scenario_name": "Happy path",
      "condition": "...",
      "spec_behavior": "...",
      "coverage": "OK",
      "suggestion": "..."
    }
  ]
}
end note
 
' --- Step 5: Final summary ---
API -> LLM : prompt#5 – compose final summary
note right of API
{
  "topic_reviews": [...],
  "scenarios": [...],
  "metadata": {
    "title": "...",
    "version": "R19"
  }
}
end note
 
LLM --> API
note left
{
  "summary": { ... },
  "topic_review_table": [...],
  "scenario_coverage_table": [...],
  "signature": "generated by AI Spec Review V2"
}
end note
 
' --- Optional auto comment ---
alt auto_comment == true
  API -> MCP : post_comment(confluence_link, markdown)
  note right of API
  {
    "page_url": "https://company.atlassian.net/wiki/xxxx",
    "comment_markdown": "## ✅ AI Spec Review Summary ..."
  }
  end note
end
 
API --> UI : 200 OK (final_review_json)
 
deactivate API
UI --> User : Render Summary / Tables
 
@enduml